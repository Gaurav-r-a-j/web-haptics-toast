{
  "name": "web-haptics-toast",
  "version": "1.0.0",
  "description": "Standalone React toasts with built-in haptics and a Sonner-compatible API. Single dependency—no separate haptics package.",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "default": "./dist/index.js"
    },
    "./dist/styles.css": "./dist/styles.css"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bunchee --watch",
    "build": "bunchee && cp src/styles.css dist/styles.css",
    "type-check": "tsc --noEmit",
    "dev:website": "turbo run dev --filter=website...",
    "dev:test": "turbo run dev --filter=test...",
    "format": "prettier --write .",
    "test": "playwright test"
  },
  "keywords": [
    "react",
    "notifications",
    "toast",
    "snackbar",
    "message",
    "haptics",
    "vibration",
    "web-haptics"
  ],
  "author": "DesignByte <https://studio.designbyte.dev>",
  "license": "MIT",
  "homepage": "https://web-haptics-toast.designbyte.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Gaurav-r-a-j/web-haptics-toast.git"
  },
  "pnpm": {
    "overrides": {
      "next-mdx-remote": "6.0.0",
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
    }
  },
  "bugs": {
    "url": "https://github.com/Gaurav-r-a-j/web-haptics-toast/issues"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/node": "^18.11.13",
    "@types/react": "19.2.14",
    "bunchee": "6.3.3",
    "prettier": "^2.8.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "turbo": "^1.13.0",
    "typescript": "^5.7.2"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0 || ^19.0.0-rc",
    "react-dom": "^18.0.0 || ^19.0.0 || ^19.0.0-rc"
  },
  "packageManager": "pnpm@9.15.9"
}
